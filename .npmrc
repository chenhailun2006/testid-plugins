# npm 是默认 registry，无需额外配置
# 修复 vue-template-compiler@2.7.16 在 pnpm workspace 中 peer dep vue 被 hoisted vue@3 劫持的问题
# 让 pnpm 将 vue@2 注入到 vue-template-compiler 的依赖树中
package_extensions.vue-template-compiler@2.7.16.peerDependencies.vue=^2.7.16
package_extensions.vue-template-compiler@2.7.16.dependencies.vue=^2.7.16
